# Backend
CSD_HOST=127.0.0.1
CSD_PORT=8000
CSD_USE_GPU=0
CSD_CT_MODEL_PATH=ml/models/nsclc_stage_classifier.keras
CSD_XRAY_MODEL_PATH=ml/models/archive/nih_binary_xray_model.h5
CSD_PATHOLOGY_MODEL_PATH=ml/models/pathology/checkpoints/1/best_lung_tf.keras

# Frontend
FASTAPI_BASE_URL=https://api.hudaib2009.xyz
OPENROUTER_API_KEY=replace-me
OPENROUTER_MODEL=tngtech/deepseek-r1t2-chimera:free
OPENROUTER_FALLBACK_MODEL=moonshotai/kimi-k2:free
OPENROUTER_FALLBACK_MODEL_2=openai/gpt-4o-mini

# Access control
# In production, keep CSD_ALLOW_UNAUTHENTICATED=0 and set both credentials.
CSD_ALLOW_UNAUTHENTICATED=0
CSD_BASIC_AUTH_USERNAME=change-me
CSD_BASIC_AUTH_PASSWORD=change-me
